{
  "name": "ps-billing",
  "version": "1.0.0",
  "description": "PS Rental Billing System - Built with Hono + Bun + SQLite",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
